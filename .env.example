# Copy to .env (gitignored) and fill in. Off-chain scanner config.

# --- Network (target = mainnet; that's where the CLMM venues + measured edge live) ---
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_WS_URL=wss://fullnode.mainnet.sui.io:443

# --- Deployment ---
# Published arbitrage_system package id (from `sui client publish`).
ARB_PACKAGE_ID=0x0
# Base token every cycle starts/ends in (fully-qualified coin type).
ARB_BASE_TOKEN=0x2::sui::SUI

# --- Strategy (all amounts in MIST; 1 SUI = 1_000_000_000 MIST) ---
# Minimum NET profit required to submit (after gas).
ARB_MIN_PROFIT=10000000
# Gas budget per PTB.
ARB_GAS_BUDGET=20000000
# Gas estimate charged against gross profit when sizing trades.
ARB_GAS_COST=8000000
# Max cycle length (3 = triangular arbitrage).
ARB_MAX_HOPS=3
# Optional explicit input sizes to probe, comma-separated MIST.
# ARB_CANDIDATE_INPUTS=100000000,500000000,1000000000
# Re-scan cadence (ms) when not purely event-driven.
ARB_POLL_MS=500
# Pools to track (live), "<dex>:<object_id>" comma-separated. dex = cetus|turbos|amm_v2.
# ARB_TRACKED_POOLS=cetus:0xPOOL_A,turbos:0xPOOL_B

# --- Live execution gates (feature = "live") ---
# Master submit switch. OFF = detect + authoritatively re-quote + dry-run only.
ARB_SUBMIT_ENABLED=false
# Re-quote if the authoritative quote is older than this before submit (ms).
ARB_MAX_QUOTE_AGE_MS=1500
# Per-hop min_out slippage floor (bps) derived from the dry-run, to fail a stale route cheap.
ARB_PER_HOP_SLIPPAGE_BPS=30
# Signing (key stays in the keystore; never logged) + the deployed package + venue objects.
ARB_PACKAGE_ID=0x0
ARB_SENDER_ADDRESS=0x0
ARB_KEYSTORE_PATH=
ARB_CETUS_GLOBAL_CONFIG_ID=0x0
ARB_TURBOS_VERSIONED_ID=0x0

# --- Risk / ops ---
# Pool ids to never route through (broken/empty pools, e.g. the Momentum USDB/USDC pool).
# ARB_POOL_BLACKLIST=0xBROKENPOOL
# Hard halt — submits nothing when true.
ARB_KILL_SWITCH=false
# Halt submitting once realized daily P&L drops below -this (USD). 0 disables.
ARB_MAX_DAILY_LOSS_USD=0

# Flash loans — execute arbitrage with borrowed capital (see docs/flash-loan-design.md).
# Off by default; owned-capital execution is unchanged when disabled.
ARB_FLASH_ENABLED=false
# Provider resolved by flashloan::provider_from: "mock" (in-package vault) or "scallop".
ARB_FLASH_PROVIDER=mock
# Loan fee in bps, netted from profit when sizing (must match the provider's real fee).
ARB_FLASH_FEE_BPS=0
# Shared lender object: mock = flash vault; scallop = Market object.
ARB_FLASH_LENDER_ID=0x0
# Provider secondary object (scallop = Version object); unused by the mock vault.
ARB_FLASH_VERSION_ID=0x0

# --- Liquidations (opportunity source; paper unless ARB_SUBMIT_ENABLED=true) ---
ARB_LIQ_ENABLED=false
# Scallop shared objects for liquidate: Market = ARB_FLASH_LENDER_ID, Version = ARB_FLASH_VERSION_ID,
# plus the x_oracle and coin-decimals registry + protocol package:
ARB_SCALLOP_X_ORACLE_ID=0x0
ARB_SCALLOP_REGISTRY_ID=0x0
# ARB_SCALLOP_PACKAGE_ID defaults to the verified mainnet protocol id.
# In-PTB oracle refresh (Scallop x_oracle pyth_rule). pyth_rule pkg defaults to the verified id.
ARB_X_ORACLE_PACKAGE_ID=0x0
# ARB_PYTH_RULE_PACKAGE_ID=0x1cf913c825c202cbbb71c378edccb9c04723fa07a73b88677b2ef89c6e203a85
ARB_PYTH_STATE_ID=0x0
ARB_SCALLOP_PYTH_REGISTRY_ID=0x0
# Per-coin Pyth PriceInfoObject ids: "<coin_type>=<object_id>,<coin_type>=<object_id>"
# ARB_PYTH_PRICE_INFO_OBJECTS=0x2::sui::SUI=0x..,0x..::usdc::USDC=0x..

# Logging
RUST_LOG=info

# Copy to .env (gitignored) and fill in. Off-chain scanner config.

# --- Network (target = mainnet; that's where the CLMM venues + measured edge live) ---
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_WS_URL=wss://fullnode.mainnet.sui.io:443

# --- Deployment ---
# Published arbitrage_system package id (from `sui client publish`).
ARB_PACKAGE_ID=0x0
# Base token every cycle starts/ends in (fully-qualified coin type).
ARB_BASE_TOKEN=0x2::sui::SUI

# --- Strategy (all amounts in MIST; 1 SUI = 1_000_000_000 MIST) ---
# Minimum NET profit required to submit (after gas).
ARB_MIN_PROFIT=10000000
# Gas budget per PTB.
ARB_GAS_BUDGET=20000000
# Gas estimate charged against gross profit when sizing trades.
ARB_GAS_COST=8000000
# Max cycle length (3 = triangular arbitrage).
ARB_MAX_HOPS=3
# Optional explicit input sizes to probe, comma-separated MIST.
# ARB_CANDIDATE_INPUTS=100000000,500000000,1000000000
# Re-scan cadence (ms) when not purely event-driven.
ARB_POLL_MS=500
# --- Pool discovery ---
# Automatic on-chain pool indexer (DEFAULT ON). Discovers + maintains the pool graph from
# creation events; when true, ARB_TRACKED_POOLS is IGNORED — zero manual pool config.
ARB_INDEXER_ENABLED=true
ARB_INDEXER_DEXES=cetus,turbos          # cetus|turbos|deepbook (deepbook = discover-only)
ARB_INDEXER_MIN_LIQUIDITY=0             # drop pools below this raw liquidity (set in prod)
ARB_INDEXER_MAX_POOLS=300               # keep top-N pools per DEX by liquidity (bounds RPC)
ARB_INDEXER_DISCOVERY_SECS=300          # how often to re-scan for newly-listed pools
ARB_INDEXER_REFRESH_SECS=10             # how often to refresh active pool state (poll mode)
# ARB_INDEXER_QUOTE_TOKENS=0x2::sui::SUI,0x..::usdc::USDC   # optional: keep only pools w/ these
#
# Manual fallback (only used when ARB_INDEXER_ENABLED=false):
# "<dex>:<object_id>" comma-separated. dex = cetus|turbos|amm_v2.
# ARB_TRACKED_POOLS=cetus:0xPOOL_A,turbos:0xPOOL_B

# --- Live execution gates (feature = "live") ---
# Master submit switch. OFF = detect + authoritatively re-quote + dry-run only.
ARB_SUBMIT_ENABLED=false
# Re-quote if the authoritative quote is older than this before submit (ms).
ARB_MAX_QUOTE_AGE_MS=1500
# Per-hop min_out slippage floor (bps) derived from the dry-run, to fail a stale route cheap.
ARB_PER_HOP_SLIPPAGE_BPS=30
# Signing (key stays in the keystore; never logged) + the deployed package + venue objects.
ARB_PACKAGE_ID=0x0
ARB_SENDER_ADDRESS=0x0
ARB_KEYSTORE_PATH=
ARB_CETUS_GLOBAL_CONFIG_ID=0x0
ARB_TURBOS_VERSIONED_ID=0x0

# --- Risk / ops ---
# Pool ids to never route through (broken/empty pools, e.g. the Momentum USDB/USDC pool).
# ARB_POOL_BLACKLIST=0xBROKENPOOL
# Hard halt — submits nothing when true.
ARB_KILL_SWITCH=false
# Halt submitting once realized daily P&L drops below -this (USD). 0 disables.
ARB_MAX_DAILY_LOSS_USD=0

# Flash loans — execute arbitrage with borrowed capital (see docs/flash-loan-design.md).
# Off by default; owned-capital execution is unchanged when disabled.
ARB_FLASH_ENABLED=false
# Provider resolved by flashloan::provider_from: "mock" (in-package vault) or "scallop".
ARB_FLASH_PROVIDER=mock
# Loan fee in bps, netted from profit when sizing (must match the provider's real fee).
ARB_FLASH_FEE_BPS=0
# Shared lender object: mock = flash vault; scallop = Market object.
ARB_FLASH_LENDER_ID=0x0
# Provider secondary object (scallop = Version object); unused by the mock vault.
ARB_FLASH_VERSION_ID=0x0

# --- Liquidations (opportunity source; paper unless ARB_SUBMIT_ENABLED=true) ---
# IDs below are VERIFIED against mainnet (tx AYdhgWMq…, obligation 0xa042dcfd…).
# Full ground truth + remaining items: docs/scallop-liquidation-verified.md
ARB_LIQ_ENABLED=false
# Sizing knobs (defaults shown):
ARB_LIQ_CLOSE_FACTOR=0.5
ARB_LIQ_BONUS=0.05
ARB_LIQ_HEALTH_MARGIN=0.02
# Per-asset metadata "<coin_type>=<decimals>:<liq_threshold>:<borrow_weight>" (price from oracle):
# ARB_LIQ_ASSETS=0x2::sui::SUI=9:0.7:1.0,0xdba34672…::usdc::USDC=6:0.8:1.0
# Scallop shared objects for liquidate (Market = ARB_FLASH_LENDER_ID, Version = ARB_FLASH_VERSION_ID):
ARB_FLASH_LENDER_ID=0xa757975255146dc9686aa823b7838b507f315d704f428cbadad2f4ea061939d9   # Scallop Market (VERIFIED)
ARB_FLASH_VERSION_ID=0x07871c4b3c847a0f674510d4978d5cf6f960452795e8ff6f189fd2088a3f6ac7  # Scallop Version (VERIFIED)
ARB_SCALLOP_X_ORACLE_ID=0x93d5bf0936b71eb27255941e532fac33b5a5c7759e377b4923af0a1359ad494f   # XOracle (VERIFIED)
ARB_SCALLOP_REGISTRY_ID=0x200abe9bf19751cc566ae35aa58e2b7e4ff688fc1130f8d8909ea09bc137d668   # CoinDecimalsRegistry (VERIFIED)
# ARB_SCALLOP_PACKAGE_ID defaults to the verified mainnet protocol id (0xefe8b36d…).
ARB_PYTH_STATE_ID=0x1f9310238ee9298fb703c3419030b35b22bb1cc37113e3bb5007c99aec79e5b8        # Pyth State (VERIFIED)
ARB_X_ORACLE_PACKAGE_ID=0x0          # only used by the legacy x_oracle-splice path (being migrated, see doc §6)
ARB_SCALLOP_PYTH_REGISTRY_ID=0x0
# Per-coin Pyth PriceInfoObject ids + feed ids (both needed for the verified liquidation
# Pyth-accumulator flow — doc §4/§5):
# ARB_PYTH_PRICE_INFO_OBJECTS=0x2::sui::SUI=0x..,0x..::usdc::USDC=0x..
# ARB_PYTH_FEED_IDS=0x2::sui::SUI=<pyth_feed_hex>,0x..::usdc::USDC=<pyth_feed_hex>
# Wormhole/Pyth State + packages default to the verified mainnet ids (doc §5); override only if needed:
# ARB_WORMHOLE_STATE_ID / ARB_WORMHOLE_PACKAGE_ID / ARB_PYTH_PACKAGE_ID
# ARB_HERMES_URL=https://hermes.pyth.network   # Pyth Hermes accumulator endpoint
# ARB_PYTH_FEE=1                               # MIST per update_single_price_feed

# Observability (Prometheus). Exposes GET /metrics; empty disables the endpoint.
ARB_METRICS_ADDR=0.0.0.0:9100

# Logging — configurable levels via RUST_LOG (e.g. info, debug, arb_scanner=debug,warn).
RUST_LOG=info
